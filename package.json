{
  "name": "sqlproj-erdforge",
  "displayName": "SqlprojErdForge",
  "description": "Live, bidirectional ERD for SQL Server database projects (.sqlproj).",
  "version": "0.1.0",
  "publisher": "internal",
  "private": true,
  "type": "module",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onCommand:erdforge.openErd"],
  "main": "./out/extension.cjs",
  "contributes": {
    "commands": [
      {
        "command": "erdforge.openErd",
        "title": "Open ERD",
        "category": "ErdForge"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "erdforge.openErd",
          "when": "resourceExtname == .sqlproj",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "erdforge.openErd",
          "when": "resourceExtname == .sqlproj || editorLangId == xml"
        }
      ]
    }
  },
  "scripts": {
    "spike": "node src/cli.ts",
    "spike:real": "node src/cli.ts --real",
    "verify:p1": "node src/cli.ts --verify-p1",
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.extension.json && tsc --noEmit -p tsconfig.webview.json",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "@xyflow/react": "^12.6.0",
    "elkjs": "^0.10.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.0"
  }
}
